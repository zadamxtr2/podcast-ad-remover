# Core API Keys (At least one is recommended)
# GEMINI_API_KEY supports multiple keys comma-separated for automatic failover
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Application Settings
SESSION_SECRET_KEY=replace-with-a-long-random-secret
LOG_LEVEL=INFO
CHECK_INTERVAL_MINUTES=60
BASE_URL=http://localhost:8000
COOKIE_SECURE=false
TRUST_PROXY_HEADERS=false
MAX_FEED_BYTES=10485760
MAX_DOWNLOAD_BYTES=1572864000
MIN_FREE_SPACE_BYTES=1073741824
FFMPEG_TIMEOUT_SECONDS=7200
ALLOW_PRIVATE_FEEDS=true

# Whisper Configuration
WHISPER_MODEL=base
