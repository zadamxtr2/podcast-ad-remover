{
  "name": "podcast-ad-remover",
  "version": "1.8.0",
  "description": "Self-hosted podcast processing app that downloads episodes, removes ads with local transcription and LLM analysis, and publishes replacement RSS feeds.",
  "private": true,
  "scripts": {
    "test": "npm run verify",
    "build:css": "tailwindcss -i ./app/web/static/css/input.css -o ./app/web/static/css/output.css --minify",
    "watch:css": "tailwindcss -i ./app/web/static/css/input.css -o ./app/web/static/css/output.css --watch",
    "verify": "python scripts/verify.py",
    "verify:docker": "python scripts/verify.py --docker",
    "db:migration-dry-run": "python scripts/migration_dry_run.py",
    "docker:build": "python scripts/publish_docker.py",
    "docker:publish": "python scripts/publish_docker.py --push",
    "docker:experimental": "python scripts/publish_experimental_docker.py",
    "docker:experimental:arm64": "python scripts/publish_experimental_docker.py --platform linux/arm64 --no-tts --tag experimental-arm64"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdcb4/podcast-ad-remover.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/jdcb4/podcast-ad-remover/issues"
  },
  "homepage": "https://github.com/jdcb4/podcast-ad-remover#readme",
  "devDependencies": {
    "autoprefixer": "^10.4.23",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
